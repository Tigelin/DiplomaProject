{
  "buildCommand": "bash build_files.sh",
  "installCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "core/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12",
        "includeFiles": "staticfiles/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/core/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "/core/wsgi.py"
    }
  ]
}